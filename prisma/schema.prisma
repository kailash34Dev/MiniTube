generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id               String   @id
  original_name    String
  saved_name       String
  mime_type        String
  actual_size      Int
  processed_size   Int
  title            String
  description      String
  category         String
  tags             String[]
  thumbnail_path   String
  upload_path      String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("videos")
}
