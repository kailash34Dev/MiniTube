// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id            String   @id
  original_name String
  saved_name    String
  mime_type     String
  size          Int
  upload_path   String
  created_at    DateTime @default(now())

  @@map("videos")
}
